# =============================================================================
# Anthropic API
# =============================================================================
# Required for Tier A (Haiku triage), Tier B (Sonnet investigation), and
# Tier C (Opus reflection). Get a key at console.anthropic.com.
ANTHROPIC_API_KEY=sk-ant-...

# =============================================================================
# Slack — multi-token model
# =============================================================================
# The agent supports routing each channel pull to a token whose owner is a
# member of that channel. This works around private-channel access asymmetry
# in workspaces without Discovery API. See scripts/lib/slack-token-router.mjs.
#
# Each token is a USER token (xoxp-...) from one of your audience execs.
# Required scopes: channels:history, channels:read, groups:history,
# groups:read, mpim:read, im:read, users:read, users:read.email,
# chat:write (only on the token used for sending DMs).
#
# At minimum, set SLACK_TOKEN_<NAME> for each owner the router should route
# through. Names map to the KNOWN_OWNERS list in slack-token-router.mjs.
SLACK_TOKEN_OWNER1=xoxp-...
SLACK_TOKEN_OWNER2=xoxp-...
SLACK_TOKEN_OWNER3=xoxp-...

# Optional: dedicated bot token for posting digest DMs (preferred over reusing
# a user token). Falls back to SLACK_TOKEN_OWNER1 if unset.
SLACK_BOT_TOKEN_BOT=xoxb-...

# Optional: Socket Mode app-level token if running scripts/slack-daemon.mjs
# for live event ingest (not required for the batch ingest pipeline).
SLACK_APP_TOKEN=xapp-...

# =============================================================================
# Front (via Snowflake/Frosty proxy)
# =============================================================================
# This project pulls Front data from a Snowflake schema populated by your
# Front-to-Snowflake pipeline (e.g., a curated FRONT_ESCALATION schema with
# CONVERSATION_SUMMARY + THREAD_FLAT views). Direct Front API ingest is not
# implemented; you would need to add it to scripts/ingest-front.mjs.
#
# Frosty is a thin local proxy that fronts Snowflake — see your data team's
# setup. Replace with direct Snowflake credentials or your own warehouse
# proxy if you don't use Frosty.
FROSTY_BASE_URL=http://localhost:8888
FROSTY_SQL_WAREHOUSE=AD_HOC_WH
FROSTY_REQUEST_TIMEOUT_MS=30000

# =============================================================================
# Optional: org-specific integrations
# =============================================================================
# T3OS_API_KEY etc. are placeholders for whatever internal systems you tie
# into for entity resolution (employee directory, asset DB, customer roster).
# T3OS_API_KEY=...
